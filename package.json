{
  "name": "cf-forklift",
  "description": "Structured parallelism for Cloudflare Workflows",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun run test:types && vitest run",
    "test:types": "tsc -p tests/tsconfig.json --noEmit",
    "test:watch": "vitest",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "workflow",
    "fork",
    "join",
    "parallel",
    "fan-out",
    "fan-in",
    "durable"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.12",
    "@cloudflare/workers-types": "^4.20260606.1",
    "@types/bun": "^1.3.13",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.97.0"
  }
}
