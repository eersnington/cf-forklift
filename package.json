{
  "name": "cf-forklift",
  "version": "0.1.0",
  "description": "Structured parallelism for Cloudflare Workflows",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "workflow",
    "fork",
    "join",
    "parallel",
    "fan-out",
    "fan-in",
    "durable"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@cloudflare/workers-types": ">=4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.9.0",
    "@cloudflare/workers-types": "^4.20260602.1",
    "@types/bun": "^1.3.13",
    "tsdown": "^0.22.1",
    "typescript": "^6.0.3"
  },
  "private": true
}
